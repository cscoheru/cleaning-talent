# AI Service 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================================================
# 应用配置
# ============================================================================
APP_NAME=LMS AI Service
APP_VERSION=0.1.0
DEBUG=false

# 服务配置
HOST=0.0.0.0
PORT=8000

# ============================================================================
# 数据库配置
# ============================================================================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:password@localhost:5432/cleaning_talent_demo

# 或者使用分离的配置
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cleaning_talent_demo
# DB_USER=postgres
# DB_PASSWORD=password

# ============================================================================
# AI 服务配置
# ============================================================================
# 通义千问 API Key (从 https://dashscope.aliyun.com 获取)
QWEN_API_KEY=your_qwen_api_key_here

# OpenAI API Key (可选，用于其他模型)
OPENAI_API_KEY=

# 默认模型选择: qwen-turbo, qwen-plus, qwen-max
DEFAULT_MODEL=qwen-turbo

# ============================================================================
# CORS 配置
# ============================================================================
# 允许的跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://lms-demo.vercel.app,https://lms-backend.railway.app

# ============================================================================
# 对话历史配置
# ============================================================================
# 每个用户最多保存的历史记录数量
MAX_HISTORY_LENGTH=10

# ============================================================================
# 安全限制
# ============================================================================
# 问题的最大长度（字符数）
MAX_QUESTION_LENGTH=1000

# 上下文的最大长度（字符数）
MAX_CONTEXT_LENGTH=5000
