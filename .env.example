# 环境变量配置模板
# 使用：复制此文件为 .env 并填写真实值

# ================================
# 数据库配置
# ================================
# 本地开发使用 docker-compose.dev.yml 启动的数据库
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/cleaning_talent_demo
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cleaning_talent_demo
DATABASE_USER=postgres
DATABASE_PASSWORD=dev_password

# 生产环境使用节点 A 的数据库
# DATABASE_URL=postgresql://postgres:WhjQTPAwInc5Vav3sDWe@139.224.42.111:5432/cleaning_talent_demo

# ================================
# Redis 配置
# ================================
# 本地开发
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# 生产环境使用节点 A 的 Redis
# REDIS_URL=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379

# ================================
# MinIO 对象存储配置
# ================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cleaning-talent-demo
MINIO_USE_SSL=false

# 生产环境使用节点 A 的 MinIO
# MINIO_ENDPOINT=139.224.42.111:9000
# MINIO_ACCESS_KEY=admin
# MINIO_SECRET_KEY=xhOSMeHNmxCgNTBpoQfH
# MINIO_USE_SSL=false

# ================================
# AI 服务配置
# ================================
# 通义千问 API Key（需要自己申请）
QWEN_API_KEY=your_qwen_api_key_here

# 可选：OpenAI API Key
# OPENAI_API_KEY=your_openai_api_key_here

# ================================
# JWT 配置
# ================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=604800  # 7 天（秒）

# ================================
# 应用配置
# ================================
APP_NAME=cleaning_Talent
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:5173

# API 地址
API_BASE_URL=http://localhost:8080
AI_SERVICE_URL=http://localhost:8000

# ================================
# 部署配置
# ================================
# Vercel 部署URL
VERCEL_URL=https://lms-demo.vercel.app

# Railway 部署URL
RAILWAY_URL=https://lms-backend.railway.app

# 节点 A
NODE_A_HOST=139.224.42.111
NODE_A_USER=root
